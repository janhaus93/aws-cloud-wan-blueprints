{
  "version": "2025.11",
  "core-network-configuration": {
    "vpn-ecmp-support": false,
    "inside-cidr-blocks": ["10.100.0.0/16"],
    "asn-ranges": ["64512-65534"],
    "edge-locations": [
      {
        "location": "eu-central-1",
        "inside-cidr-blocks": ["10.100.1.0/24"]
      },
      {
        "location": "us-east-1",
        "inside-cidr-blocks": ["10.100.0.0/24"]
      }
    ]
  },
  "segments": [
    {
      "name": "Hybrid",
      "description": "SD-WAN-facing segment for hub VPCs",
      "require-attachment-acceptance": false
    },
    {
      "name": "Prod",
      "description": "Direct-attached prod segment",
      "require-attachment-acceptance": false
    }
  ],
  "segment-actions": [
    {
      "action": "share",
      "mode": "attachment-route",
      "segment": "Hybrid",
      "share-with": ["Prod"]
    },
    {
      "action": "share",
      "mode": "attachment-route",
      "segment": "Prod",
      "share-with": ["Hybrid"]
    }
  ],
  "attachment-policies": [
    {
      "rule-number": 100,
      "condition-logic": "or",
      "conditions": [
        {
          "type": "tag-value",
          "operator": "equals",
          "key": "segment",
          "value": "Hybrid"
        }
      ],
      "action": {
        "association-method": "constant",
        "segment": "Hybrid"
      }
    },
    {
      "rule-number": 200,
      "condition-logic": "or",
      "conditions": [
        {
          "type": "tag-value",
          "operator": "equals",
          "key": "segment",
          "value": "Prod"
        }
      ],
      "action": {
        "association-method": "constant",
        "segment": "Prod"
      }
    }
  ]
}
